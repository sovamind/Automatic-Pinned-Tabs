{
  "manifest_version": 3,
  "name": "Automatic Pinned Tabs",
  "version": "1.3.0",
  "description": "Automatically creates pinned tabs in every new window.",
  "permissions": ["tabs", "storage", "sessions"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/ms-edge-16.png",
    "32": "icons/ms-edge-32.png",
    "48": "icons/ms-edge-48.png",
    "128": "icons/ms-edge-128.png"
  }
}
