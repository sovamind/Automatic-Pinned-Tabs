{
  "manifest_version": 3,
  "name": "Automatic Pinned Tabs",
  "version": "1.3.0",
  "description": "Automatically opens and pins your chosen tabs in every new browser window.",
  "permissions": ["tabs", "storage", "sessions"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Automatic Pinned Tabs"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
